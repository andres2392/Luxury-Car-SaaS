PROJECT_NAME=Luxury-Car-SaaS Backend
API_V1_STR=/api/v1

# PostgreSQL. Use DATABASE_URL for hosted databases, or the individual
# POSTGRES_* fields for local development.
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=luxury_car_saas
POSTGRES_USER=luxury_admin
POSTGRES_PASSWORD=replace-with-local-password
DATABASE_URL=

# JWT signing. Use a long random production secret.
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated explicit origins only. Do not use * with credentials.
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
ADMIN_EMAIL=admin@luxury.owner

# Supabase Storage. Service role key belongs on the backend only.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=car-images
